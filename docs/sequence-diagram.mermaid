sequenceDiagram
    actor User as 用户
    participant MW as MainWindow
    participant TP as TaskPage
    participant TM as TaskManager
    participant AR as ActionRecorder
    participant TW as TaskWorker
    participant TE as TaskEngine
    participant CTRL as Controller
    participant VIS as Vision
    participant HS as HistoryStore

    %% ═══════════════════════════════════════════
    %% 场景1: 启动软件 — 任务清单
    %% ═══════════════════════════════════════════

    rect rgb(240, 245, 255)
        Note over User,HS: 【场景1】启动软件 → 看到任务清单
        User->>MW: 打开 SmartRPA
        MW->>MW: __init__()
        MW->>TP: 创建 TaskPage
        TP->>TM: scan_tasks()
        TM->>TM: 扫描 data_dir("tasks")/
        TM->>TM: 扫描 examples/
        TM-->>TP: List~TaskInfo~
        TP->>TP: _add_task_checklist_item() × N
        TP->>TP: 显示任务清单 + 引导提示
        MW->>MW: show() → 首页 = 任务清单
    end

    %% ═══════════════════════════════════════════
    %% 场景2: 录制操作
    %% ═══════════════════════════════════════════

    rect rgb(255, 245, 240)
        Note over User,HS: 【场景2】点击"录制" → 操作 → F6 停止
        User->>TP: 点击"录制"按钮
        TP->>AR: 创建 ActionRecorder(stop_key="Key.f6")
        TP->>AR: start()
        TP->>MW: showMinimized()
        Note over AR: 启动 pynput mouse/keyboard listener

        User->>User: 在目标窗口操作
        AR->>AR: on_click() → events.append(ts, "click", (x,y))
        AR->>TP: log.emit("📍 点击 (450, 320)", "INFO")
        AR->>AR: on_press() → events.append(ts, "press", key)
        AR->>TP: log.emit("⌨ 按键 enter", "INFO")

        User->>AR: 按下 F6
        AR->>AR: _active = False → 停止监听

        AR->>AR: _build_task()
        AR->>AR: 过滤重复事件
        AR->>AR: 为每个 click 截图 60×60 → 保存模板
        AR->>AR: 生成 task.json (template定位 + 0.7阈值)
        AR->>TP: log.emit("录制完成: 8步", "SUCCESS")
        AR->>TP: finished.emit(task_path)
        TP->>TM: scan_tasks() 重新扫描
        TP->>TP: 新任务出现在清单中
        TP->>MW: showNormal()
    end

    %% ═══════════════════════════════════════════
    %% 场景3: 运行任务
    %% ═══════════════════════════════════════════

    rect rgb(240, 255, 240)
        Note over User,HS: 【场景3】勾选任务 → 运行 → 自动执行
        User->>TP: 勾选任务 A、任务 B
        User->>TP: 点击"开始运行"
        TP->>TP: 收集所有已勾选任务名
        TP->>MW: showMinimized()
        TP->>TP: _queue_index = 0

        Note over TP,TW: 执行第一个任务 (任务A)
        TP->>TW: 创建 TaskWorker(task_file, tpl_dir, ...)
        TP->>TW: start()

        TW->>TW: _is_bt_format(task_file)
        alt 经典 JSON 格式
            TW->>TE: 创建 TaskEngine(controller, vision, popup)
            TW->>TE: load(task_file)
            TW->>TE: set_window_title(win_title)
            TW->>TE: run(entry)

            loop 每个步骤
                TE->>CTRL: screenshot()
                CTRL-->>TE: ndarray
                TE->>TE: _execute_step(screenshot, task)

                alt click + template
                    TE->>VIS: find(screenshot, "s1", threshold=0.7)
                    VIS->>VIS: _load_template("s1") → 从缓存/磁盘
                    VIS->>VIS: multi_scale template matching
                    VIS-->>TE: Found(found=True, center=(450,320))
                    TE->>CTRL: click(450, 320)
                    CTRL->>CTRL: _human.move_to() + click
                else press
                    TE->>CTRL: press_key("enter")
                end

                TE->>TW: _user_log / step signal
                TW->>TP: log.emit("点击 s1.png", "INFO")
                TW->>TP: step.emit("点击 s1.png")
            end

            TE-->>TW: run() 完成
            TW->>TP: finished.emit(stats)
            TW->>TP: log.emit("完成: 8步 0弹窗 0错误", "SUCCESS")

        else BT 格式
            TW->>TW: 创建 BTEngine(controller, vision, popup)
            Note over TW: BT 执行流程类似，省略
        end

        TP->>HS: add_record(task_name, stats)
        TP->>MW: showNormal()

        Note over TP: 继续下一个勾选任务 (任务B)
        TP->>TP: _queue_index = 1
        Note over TP,TW: 重复上述流程...
        TP->>TP: 所有任务完成
        TP->>MW: showNormal()
        TP->>TP: log_msg("所有任务执行完成", "SUCCESS")
    end

    %% ═══════════════════════════════════════════
    %% 场景4: 重命名任务
    %% ═══════════════════════════════════════════

    rect rgb(255, 255, 240)
        Note over User,HS: 【场景4】重命名任务
        User->>TP: 右键任务 → "重命名"
        TP->>TP: 弹出 QInputDialog
        User->>TP: 输入新名称 → 确认
        TP->>TM: rename_task(old_name, new_name)
        TM->>TM: 修改 task.json 中 _meta.name
        TM->>TM: 更新 _task_map
        TM-->>TP: True
        TP->>TP: scan_tasks() 刷新列表
    end

    %% ═══════════════════════════════════════════
    %% 场景5: 查看历史
    %% ═══════════════════════════════════════════

    rect rgb(245, 240, 255)
        Note over User,HS: 【场景5】切换到历史页查看运行记录
        User->>MW: 点击侧边栏"历史"
        MW->>MW: _switch_page(1)
        MW->>HP: 显示 HistoryPage
        HP->>HS: query(limit=50)
        HS->>HS: 读取 history/YYYY-MM.json
        HS-->>HP: List~dict~
        HP->>HP: 渲染历史列表 + 统计
        HP->>HS: get_stats()
        HS-->>HP: {total: 42, success: 38, failed: 4}
        HP->>HP: 显示统计摘要
    end
