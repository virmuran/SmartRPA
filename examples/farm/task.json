{
    "_comment": "游戏重复刷本自动化（通用模板）",
    "_note": "需要截取以下模板图片放到 templates/ 目录：",
    "_templates": [
        "battle_btn - 战斗/挑战按钮",
        "ready_btn - 准备/确认按钮",
        "victory_btn - 胜利后确认按钮",
        "close_ad_btn - 关闭广告按钮（弹窗处理用）"
    ],

    "StartFarming": {
        "desc": "点击挑战按钮进入战斗",
        "action": "click",
        "params": { "template": "battle_btn", "threshold": 0.8 },
        "next": ["WaitBattleLoad"],
        "onErrorNext": ["StartFarming"],
        "humanDelay": "transition"
    },

    "WaitBattleLoad": {
        "desc": "等待战斗加载",
        "action": "wait",
        "params": { "seconds": 3 },
        "next": ["CheckReady"],
        "humanDelay": "read"
    },

    "CheckReady": {
        "desc": "检测准备按钮是否出现",
        "action": "find",
        "params": { "template": "ready_btn", "threshold": 0.75 },
        "next": ["ClickReady"],
        "onErrorNext": ["CheckReady"]
    },

    "ClickReady": {
        "desc": "点击准备开始战斗",
        "action": "click",
        "params": { "template": "ready_btn", "threshold": 0.75 },
        "next": ["WaitBattle"],
        "humanDelay": "think"
    },

    "WaitBattle": {
        "desc": "等待战斗过程（自动战斗）",
        "action": "wait",
        "params": { "seconds": 30 },
        "next": ["CheckVictory"],
        "humanDelay": "read"
    },

    "CheckVictory": {
        "desc": "检测胜利确认按钮",
        "action": "find",
        "params": { "template": "victory_btn", "threshold": 0.7 },
        "next": ["ClickVictory"],
        "onErrorNext": ["WaitBattle"]
    },

    "ClickVictory": {
        "desc": "确认胜利，准备下一轮",
        "action": "click",
        "params": { "template": "victory_btn", "threshold": 0.7 },
        "postDelay": 2000,
        "next": ["StartFarming"],
        "humanDelay": "transition"
    }
}
